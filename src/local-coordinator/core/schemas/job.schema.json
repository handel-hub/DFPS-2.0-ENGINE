{
	"type": "object",
	"required": ["job_id", "calculatedScore", "pipeline"],
	"properties": {
		"jobId": { "type": "string" },
		"calculatedScore": { "type": "number" },
		"pipeline": {
			"type": "object",
			"required": ["stages"],
			"properties": {
				"stages": {
					"type": "array",
					"minItems": 1,
					"items": {
						"type": "object",
						"required": ["stageId", "pluginId"],
						"additionalProperties": true,
						"properties": {
							"stageId":            { "type": "string" },
							"pluginId":           { "type": "string" },
							"dependsOn":          { "type": "array", "items": { "type": "string" }, "default": [] },
							"taskType":           { "type": "string" },
							"action":             { "type": "string" },
							"allowedWorkerTypes": { "type": "array", "items": { "type": "string" }, "default": ["ANY"] },
							"resourceClass":      { "type": "string", "default": "NORMAL" },
							"earliestStartMs":    { "type": "integer", "minimum": 0, "default": 0 },
							"deadlineMs":         { "type": ["integer", "null"], "minimum": 0 },
							"retryable":          { "type": "boolean", "default": true },
							"maxRetries":         { "type": "integer", "minimum": 0, "default": 3 },
							"isCritical":         { "type": "boolean", "default": false },
							"metadata":           { "type": "object", "additionalProperties": true }
            			}
          			}
        		}
      		}
    	}
  	}	
}
